{
  "name": "@eufelipe/agent-skills",
  "version": "1.0.0",
  "description": "CLI para instalar skills padronizadas em ferramentas de agentes de IA",
  "type": "module",
  "main": "./bin/cli.js",
  "bin": {
    "eufelipe-agent-skills": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "cli": "node bin/cli.js",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "lint": "eslint src bin --no-error-on-unmatched-pattern",
    "lint:fix": "eslint src bin --fix --no-error-on-unmatched-pattern",
    "format": "prettier --write \"src/**/*.js\" \"bin/**/*.js\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"bin/**/*.js\" \"tests/**/*.js\"",
    "type-check": "tsc --noEmit --project tsconfig.json",
    "pre-commit": "lint-staged",
    "qa": "npm run lint && npm run type-check && npm run test:coverage",
    "prepare": "husky"
  },
  "keywords": [
    "cli",
    "agent",
    "skills",
    "cursor",
    "claude-code",
    "obsidian",
    "mcp"
  ],
  "author": "eufelipe",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eufelipe/agent-skills.git"
  },
  "bugs": {
    "url": "https://github.com/eufelipe/agent-skills/issues"
  },
  "homepage": "https://github.com/eufelipe/agent-skills#readme",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "inquirer": "^9.3.8",
    "mustache": "^4.2.0",
    "node-fetch": "^3.3.2",
    "ora": "^8.2.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "c8": "^11.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix --no-error-on-unmatched-pattern",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
